# URL acessível pelo servidor Next.js. Em Docker Compose, use o nome do
# serviço Nest, por exemplo: http://api:3000
API_INTERNAL_URL=http://localhost:3001

# URL pública e canônica do frontend, usada em metadados, robots e sitemap.
SITE_URL=http://localhost:3000

# Variáveis NEXT_PUBLIC são incorporadas ao bundle durante `next build`.
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=

# Porta publicada pelo Docker Compose.
APP_PORT=3000
